
- name: Panorama Config Playbook
  hosts: all
  gather_facts: no
  connection: local
  vars_files:
    - sdwan_vars.yaml

  vars:
    provider:
      ip_address: '{{ inventory_hostname }}'
      username: '{{ username | default(omit) }}'
      password: '{{ password | default(omit) }}'

  tasks:
    - name: Refresh facts to clear the cache
      ansible.builtin.setup:
        gather_subset: '!all'

    - name: Get the system info
      paloaltonetworks.panos.panos_op:
        provider: '{{ provider }}'
        cmd: 'show system info'
      register: res

    - name: Show the system info
      ansible.builtin.debug:
        msg: '{{ res.stdout }}'

    - name: Create Panorama Objects
      ansible.builtin.include_role:
        name: pano/create_objects

    - name: Create Panorama  Object Group
      ansible.builtin.include_role:
        name: pano/create_object_group

    - name: Create Zones
      ansible.builtin.include_role:
        name: pano/create_zones

    - name: Create Virtual Routers
      ansible.builtin.include_role:
        name: pano/create_virtual_routers

    - name: Create Sub Interfaces
      ansible.builtin.include_role:
        name: pano/create_sub_interfaces

    - name: Create panorama security rules
      ansible.builtin.include_role:
        name: pano/create_security_policies
      vars:
        rule_name: '{{ security_rule_name }}'
        source_zone: ['{{ zone_name }}']
        destination_zone: ['{{ zone_name }}']
        source_ip: ['{{ object_group_name }}']
        destination_ip: ['{{ object_group_name }}']
        application: ['dtls']
        service: ['application-default']
        action: 'allow'
        tag_name: [] 
        commit: false
        device_group: '{{ device_group_name }}'

    - name: push SDWAN Template configs and force values
      paloaltonetworks.panos.panos_commit_push:
        provider: '{{ provider }}'
        style: 'template'
        name: '{{ template_name }}'
        force_template_values: true

- name: Palo Alto SDWAN Config Playbook
  hosts: all
  gather_facts: no
  connection: local
  vars_files:
    - sdwan_vars.yaml

  tasks:
    - name: Debug command
      ansible.builtin.debug:
        msg: "Executing command: request plugins vm_series aws gwlb associate vpc-endpoint '{{ vpce_name }}' interface '{{ sub_interface_name }}' on {{ device.ip_address }}"
      loop: '{{ palo_alto_devices }}'
      loop_control:
        loop_var: device

    - name: Add VPCE
      paloaltonetworks.panos.panos_op:
        provider: '{{ provider }}'
        cmd: "request plugins vm_series aws gwlb associate vpc-endpoint {{ vpce_name }} interface {{ sub_interface_name }}"

      with_items: '{{ palo_alto_devices }}'
      loop_control:
        loop_var: device
      vars:
        provider:
          ip_address: '{{ device.ip_address }}'
          username: '{{ device.username }}'
          password: '{{ device.password }}'
        panorama_primary_ip: '{{ inventory_hostname }}'

- name: Add device to device group via API
  paloaltonetworks.panos.panos_op:
    provider: '{{ provider }}'
    cmd: |
      <set>
        <device-group>
          <entry name="{{ device_group_name }}">
            <devices>
              <entry name="{{ serial }}" />
            </devices>
          </entry>
        </device-group>
      </set>
    commit: true
    with_items: '{{ device_serial_numbers }}'
    loop_control:
      loop_var: serial



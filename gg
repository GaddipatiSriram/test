- name: Add device to device group via API
  paloaltonetworks.panos.panos_op:
    provider: '{{ provider }}'
    cmd: |
      <set>
        <device-group>
          <entry name="{{ device_group_name }}">
            <devices>
              <entry name="{{ item }}" />
            </devices>
          </entry>
        </device-group>
      </set>
    commit: true
  loop: '{{ device_serial_numbers }}'

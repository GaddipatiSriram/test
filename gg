- name: Generate auth key
  shell: |
    curl -k -s -H "Content-Type: application/x-www-form-urlencoded" \
    -X POST https://{{ panorama_ip }}/api/?type=keygen \
    -d 'user={{ username }}&password={{ password }}' | \
    xmllint --xpath 'string(//response/result/key)' -
  register: auth_key_result

- name: Extract and display auth key
  debug:
    msg: "Generated Auth Key: {{ auth_key_result.stdout }}"
